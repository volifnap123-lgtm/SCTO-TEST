{
  "name": "scto-admin-app",
  "version": "1.0.0",
  "description": "Десктопное приложение для администратора СЦТО Правка Дисков",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "admin",
    "scto",
    "disk-repair"
  ],
  "author": "СЦТО Правка Дисков",
  "license": "MIT",
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.38.0"
  },
  "build": {
    "appId": "com.scto.diskstraightening.admin",
    "productName": "СЦТО Админка",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.md",
      "!**/node_modules/**/*.{ts,tsx}",
      "!**/*.map"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": "AppImage",
      "icon": "build/icon.png"
    }
  }
}